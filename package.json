{
  "name": "devloot-bot",
  "version": "1.0.0",
  "description": "DevLoot Discord Bot",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "prisma generate && nest start --watch",
